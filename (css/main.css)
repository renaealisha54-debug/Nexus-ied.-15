/* Terminal Styling */
#terminal {
    height: 150px;
    background: #000;
    color: #22c55e;
    font-family: 'Courier New', monospace;
    overflow-y: auto;
    padding: 0.5rem;
    border-top: 1px solid #1e293b;
}

/* AI Panel Styling */
#ai-panel {
    position: absolute;
    bottom: 80px;
    left: 5%;
    width: 90%;
    background: #1e293b;
    border: 1px solid #4f46e5;
    padding: 1rem;
    border-radius: 0.5rem;
    display: none;
    z-index: 100;
}

